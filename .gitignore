CLAUDE.local.md
.claude/settings.local.json

# ── Python (backend) ─────────────────────────────────────────
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
**/.venv/

# ── Environment / secrets ────────────────────────────────────
backend/.env
backend/.env.*
!backend/.env.example
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
.env*
!**/.env*.example
!.env.example

# ── Node ─────────────────────────────────────────────────────
**/node_modules/
**/.turbo/
**/*.tsbuildinfo
*.log

# ── Next.js (website) ────────────────────────────────────────
website/.next
website/out

