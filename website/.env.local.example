# Cloudflare Web Analytics — cookieless, no consent banner required
# Get your token: Cloudflare Dashboard → Analytics & Logs → Web Analytics → Add site
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# Google Search Console verification
# Get from: GSC → Settings → Ownership verification → HTML tag → content="..."
NEXT_PUBLIC_GSC_VERIFICATION=

# Bing Webmaster Tools verification
# Get from: Bing Webmaster → Settings → Site verification → HTML meta tag → content="..."
NEXT_PUBLIC_BING_VERIFICATION=

# Google Analytics 4 (optional — for organic-sourced-consultation attribution)
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# IndexNow key — must match the filename in public/ (see INDEXNOW.md)
# Generate any random string 8-128 chars: https://www.uuidgenerator.net/
NEXT_PUBLIC_INDEXNOW_KEY=
