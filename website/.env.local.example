# Cloudflare Web Analytics — cookieless, no consent banner required
# Get your token: Cloudflare Dashboard → Analytics & Logs → Web Analytics → Add site
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# Google Search Console verification
# Get from: GSC → Settings → Ownership verification → HTML tag → content="..."
NEXT_PUBLIC_GSC_VERIFICATION=

# Bing Webmaster Tools verification
# Get from: Bing Webmaster → Settings → Site verification → HTML meta tag → content="..."
NEXT_PUBLIC_BING_VERIFICATION=

# Google Analytics 4 (optional — for organic-sourced-consultation attribution)
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# IndexNow key — must match the filename in public/ (see INDEXNOW.md)
# Generate any random string 8-128 chars: https://www.uuidgenerator.net/
NEXT_PUBLIC_INDEXNOW_KEY=

# Cloudflare Turnstile — bot/scraper protection on the contact and booking forms
# Get both from: Cloudflare Dashboard → Turnstile → Add widget (pick your domain)
# Site key is public and safe to ship to the browser:
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Secret key is server-side only — for local dev, put it in .env.local (gitignored).
# In production (Cloudflare Worker) it must be set as a secret, NOT a var:
#   wrangler secret put TURNSTILE_SECRET_KEY
# If left unset, verification is skipped (fails open) so forms keep working.
TURNSTILE_SECRET_KEY=

# FastAPI backend base URL — the Next.js dev server (and the Worker, via wrangler.toml
# [vars]) proxy /api/contact and /api/book here. Defaults to http://localhost:8000.
BACKEND_URL=
