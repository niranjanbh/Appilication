# ── Dev (active by default) ───────────────────────────────────────────────────
KYROS_APP_ENV=development
KYROS_DEBUG=true
KYROS_DATABASE_URL=postgresql+asyncpg://kyros:kyros@localhost:5432/kyros
KYROS_REDIS_URL=redis://localhost:6379/0
KYROS_CELERY_BROKER_URL=redis://localhost:6379/1
KYROS_CELERY_RESULT_BACKEND=redis://localhost:6379/2
KYROS_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081
KYROS_SMTP_HOST=mailhog
KYROS_SMTP_PORT=1025
KYROS_S3_BUCKET=kyros-dev-uploads
KYROS_JWT_SECRET=CHANGEME_minimum_32_chars_xxxxxxxxxxxxxxxx
KYROS_OTP_SECRET=CHANGEME_minimum_32_chars_yyyyyyyyyyyyyyyy
KYROS_MFA_ENCRYPTION_KEY=CHANGEME_minimum_32_chars_zzzzzzzzzzzzzzzz

# ── Production (uncomment below, comment dev block above) ─────────────────────
# KYROS_APP_ENV=production
# KYROS_DEBUG=false
# KYROS_DATABASE_URL=postgresql+asyncpg://<user>:<pass>@<rds-endpoint>:5432/kyros
# KYROS_REDIS_URL=redis://<elasticache-endpoint>:6379/0
# KYROS_CELERY_BROKER_URL=redis://<elasticache-endpoint>:6379/1
# KYROS_CELERY_RESULT_BACKEND=redis://<elasticache-endpoint>:6379/2
# KYROS_CORS_ALLOWED_ORIGINS=https://kyrosclinic.com,https://www.kyrosclinic.com,https://doctor.kyrosclinic.com,https://admin.kyrosclinic.com
# KYROS_SMTP_HOST=<ses-or-sendgrid-smtp>
# KYROS_SMTP_PORT=587
# KYROS_SMTP_USER=<smtp-user>
# KYROS_SMTP_PASSWORD=<smtp-password>
# KYROS_S3_BUCKET=kyros-prod-uploads
# KYROS_JWT_SECRET=<generate-32+-random-chars>
# KYROS_OTP_SECRET=<generate-32+-random-chars>
# KYROS_MFA_ENCRYPTION_KEY=<generate-32+-random-chars>
# KYROS_RAZORPAY_KEY_ID=<live-key>
# KYROS_RAZORPAY_KEY_SECRET=<live-secret>
# KYROS_RAZORPAY_WEBHOOK_SECRET=<live-secret>
# KYROS_SENTRY_DSN=<your-sentry-dsn>
# KYROS_HMS_ACCESS_KEY=<100ms-access-key>
# KYROS_HMS_SECRET=<100ms-secret>
# KYROS_HMS_TEMPLATE_ID=<100ms-template-id>
# KYROS_AUTHKEY_API_KEY=<authkey-api-key>
# KYROS_AUTHKEY_SMS_TEMPLATE_ID=<dlt-sms-template-id>
# KYROS_GOOGLE_DOCUMENT_AI_SECRET_NAME=<aws-secret-name>
# KYROS_GOOGLE_DOCUMENT_AI_PROCESSOR_ID=<gcp-processor-resource-name>
# KYROS_GOOGLE_OAUTH_CLIENT_IDS=523700664250-e55h54jfibt7n7oj1kh4tji0h3cg2fc0.apps.googleusercontent.com,523700664250-m56sno48ofi5tde5hl7ko50dsdmqmpdc.apps.googleusercontent.com,523700664250-qfd1ptelum4vmmao7euhr9ma460879pi.apps.googleusercontent.com
# KYROS_ABHA_CLIENT_ID=<abdm-client-id>
# KYROS_ABHA_CLIENT_SECRET=<abdm-client-secret>
# KYROS_ABHA_SANDBOX_URL=https://live.abdm.gov.in
# KYROS_GST_NUMBER=<your-gst-number>
# KYROS_EMAIL_FROM=contact@kyrosclinic.com
# KYROS_ADMIN_ALERT_EMAIL=admin@kyrosclinic.com
# KYROS_OPS_NOTIFY_EMAIL=ops@kyrosclinic.com

File 2: mobile/.env.example
# ── Dev (active by default) ──
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Production (uncomment below, comment above) ──
# EXPO_PUBLIC_API_BASE_URL=https://api.kyrosclinic.com

File 3: doctor-portal/.env.example (create new)
# ── Dev (active by default) ──
VITE_API_BASE_URL=http://localhost:8000

# ── Production (uncomment below, comment above) ──
# VITE_API_BASE_URL=https://api.kyrosclinic.com

The permission block on .env* files is actually a good default — it prevents accidental secret exposure. Just copy-paste these into the files manually.
