# ── Application ───────────────────────────────────────────────────────────────
KYROS_APP_ENV=development           # development | staging | production
KYROS_APP_VERSION=0.1.0
KYROS_DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
KYROS_DATABASE_URL=postgresql+asyncpg://kyros:kyros@localhost:5432/kyros

# ── Redis ─────────────────────────────────────────────────────────────────────
KYROS_REDIS_URL=redis://localhost:6379/0

# ── Security (MUST be >=32 chars in production; app refuses to start otherwise)
KYROS_JWT_SECRET=CHANGEME_minimum_32_chars_xxxxxxxxxxxxxxxx
KYROS_JWT_ALGORITHM=HS256
KYROS_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
KYROS_JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

KYROS_OTP_SECRET=CHANGEME_minimum_32_chars_yyyyyyyyyyyyyyyy

# ── CORS ──────────────────────────────────────────────────────────────────────
KYROS_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── AWS / S3 ──────────────────────────────────────────────────────────────────
KYROS_AWS_REGION=ap-south-1
KYROS_S3_BUCKET=kyros-dev-uploads
KYROS_AWS_ACCESS_KEY_ID=
KYROS_AWS_SECRET_ACCESS_KEY=

# ── Sentry ────────────────────────────────────────────────────────────────────
KYROS_SENTRY_DSN=

# ── Celery ────────────────────────────────────────────────────────────────────
KYROS_CELERY_BROKER_URL=redis://localhost:6379/1
KYROS_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Integrations ─────────────────────────────────────────────────────────────
KYROS_RAZORPAY_KEY_ID=
KYROS_RAZORPAY_KEY_SECRET=
KYROS_RAZORPAY_WEBHOOK_SECRET=

KYROS_HMS_APP_ACCESS_KEY=
KYROS_HMS_APP_SECRET=

KYROS_MSG91_AUTH_KEY=
KYROS_MSG91_SENDER_ID=

KYROS_SENDGRID_API_KEY=
KYROS_SENDGRID_FROM_EMAIL=hello@kyros.clinic

KYROS_GOOGLE_DOCUMENT_AI_PROJECT=
KYROS_GOOGLE_DOCUMENT_AI_LOCATION=us
KYROS_GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
