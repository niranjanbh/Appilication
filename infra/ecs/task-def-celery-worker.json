{
  "family": "kyros-celery-worker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "4096",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/kyros-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/kyros-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "celery-worker",
      "image": "ACCOUNT_ID.dkr.ecr.ap-south-1.amazonaws.com/kyros-backend:IMAGE_TAG",
      "essential": true,
      "command": [
        "celery", "-A", "app.worker.celery_app", "worker",
        "--loglevel=INFO",
        "--queues=ocr,notifications,reports,payments,maintenance,default",
        "--concurrency=8",
        "--max-tasks-per-child=200"
      ],
      "secrets": [
        { "name": "KYROS_DATABASE_URL",       "valueFrom": "arn:aws:secretsmanager:ap-south-1:ACCOUNT_ID:secret:kyros/prod/backend:database_url::" },
        { "name": "KYROS_REDIS_URL",           "valueFrom": "arn:aws:secretsmanager:ap-south-1:ACCOUNT_ID:secret:kyros/prod/backend:redis_url::" },
        { "name": "KYROS_JWT_SECRET",          "valueFrom": "arn:aws:secretsmanager:ap-south-1:ACCOUNT_ID:secret:kyros/prod/backend:jwt_secret::" },
        { "name": "KYROS_OTP_SECRET",          "valueFrom": "arn:aws:secretsmanager:ap-south-1:ACCOUNT_ID:secret:kyros/prod/backend:otp_secret::" },
        { "name": "KYROS_SENTRY_DSN",          "valueFrom": "arn:aws:secretsmanager:ap-south-1:ACCOUNT_ID:secret:kyros/prod/backend:sentry_dsn::" },
        { "name": "KYROS_RAZORPAY_KEY_ID",     "valueFrom": "arn:aws:secretsmanager:ap-south-1:ACCOUNT_ID:secret:kyros/prod/backend:razorpay_key_id::" },
        { "name": "KYROS_RAZORPAY_KEY_SECRET", "valueFrom": "arn:aws:secretsmanager:ap-south-1:ACCOUNT_ID:secret:kyros/prod/backend:razorpay_key_secret::" },
        { "name": "KYROS_RAZORPAY_WEBHOOK_SECRET", "valueFrom": "arn:aws:secretsmanager:ap-south-1:ACCOUNT_ID:secret:kyros/prod/backend:razorpay_webhook_secret::" },
        { "name": "KYROS_HMS_ACCESS_KEY",      "valueFrom": "arn:aws:secretsmanager:ap-south-1:ACCOUNT_ID:secret:kyros/prod/backend:hms_access_key::" },
        { "name": "KYROS_HMS_SECRET",          "valueFrom": "arn:aws:secretsmanager:ap-south-1:ACCOUNT_ID:secret:kyros/prod/backend:hms_secret::" },
        { "name": "KYROS_MSG91_AUTH_KEY",      "valueFrom": "arn:aws:secretsmanager:ap-south-1:ACCOUNT_ID:secret:kyros/prod/backend:msg91_auth_key::" },
        { "name": "KYROS_AISENSY_API_KEY",     "valueFrom": "arn:aws:secretsmanager:ap-south-1:ACCOUNT_ID:secret:kyros/prod/backend:aisensy_api_key::" }
      ],
      "environment": [
        { "name": "KYROS_APP_ENV",    "value": "production" },
        { "name": "KYROS_AWS_REGION", "value": "ap-south-1" },
        { "name": "KYROS_S3_BUCKET",  "value": "kyros-prod-uploads" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/kyros/celery-worker",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "worker"
        }
      },
      "stopTimeout": 120
    }
  ]
}
