{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:8000",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "523700664250-e55h54jfibt7n7oj1kh4tji0h3cg2fc0.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "523700664250-m56sno48ofi5tde5hl7ko50dsdmqmpdc.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "523700664250-qfd1ptelum4vmmao7euhr9ma460879pi.apps.googleusercontent.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://staging-api.kyrosclinic.com",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "523700664250-e55h54jfibt7n7oj1kh4tji0h3cg2fc0.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "523700664250-m56sno48ofi5tde5hl7ko50dsdmqmpdc.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "523700664250-qfd1ptelum4vmmao7euhr9ma460879pi.apps.googleusercontent.com"
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.kyrosclinic.com",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "523700664250-e55h54jfibt7n7oj1kh4tji0h3cg2fc0.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "523700664250-m56sno48ofi5tde5hl7ko50dsdmqmpdc.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "523700664250-qfd1ptelum4vmmao7euhr9ma460879pi.apps.googleusercontent.com"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "niranjanb14@gmail.com",
        "ascAppId": "REPLACE_WITH_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "REPLACE_WITH_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-services-key.json",
        "track": "internal"
      }
    }
  }
}
