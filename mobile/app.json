{
  "expo": {
    "name": "Kyros",
    "slug": "kyros",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "kyros",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FAF1E4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "clinic.kyros.app",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:kyrosclinic.com",
        "applinks:www.kyrosclinic.com"
      ],
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      }
    },
    "android": {
      "package": "clinic.kyros.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0F3D2E"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "kyrosclinic.com",
              "pathPrefix": "/app"
            },
            {
              "scheme": "https",
              "host": "www.kyrosclinic.com",
              "pathPrefix": "/app"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "name": "Kyros Clinic",
      "shortName": "Kyros",
      "description": "Kyros Clinic patient portal — hormonal health, PCOS, thyroid, and more.",
      "themeColor": "#0F3D2E",
      "backgroundColor": "#FAF1E4",
      "lang": "en-IN"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0F3D2E"
        }
      ],
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    }
  }
}
