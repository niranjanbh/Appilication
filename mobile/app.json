{
  "expo": {
    "name": "Kyros Clinic",
    "slug": "kyros",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/App_logo.png",
    "userInterfaceStyle": "light",
    "scheme": "kyros",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FAF1E4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "clinic.kyros.app",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:kyrosclinic.com",
        "applinks:www.kyrosclinic.com"
      ],
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      }
    },
    "android": {
      "package": "clinic.kyros.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/App_logo.png",
        "backgroundColor": "#0F3D2E"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "kyrosclinic.com",
              "pathPrefix": "/app"
            },
            {
              "scheme": "https",
              "host": "www.kyrosclinic.com",
              "pathPrefix": "/app"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "name": "Kyros Clinic",
      "shortName": "Kyros Clinic",
      "description": "Kyros Clinic — patient portal for hormonal health, PCOS, thyroid, and more.",
      "themeColor": "#0F3D2E",
      "backgroundColor": "#FAF1E4",
      "lang": "en-IN"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0F3D2E"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Kyros Clinic uses your photos so you can attach an image to a reminder (e.g. a photo of your medication).",
          "cameraPermission": "Kyros Clinic uses your camera so you can photograph your medication for a reminder."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "b1a2763c-c321-4506-9f57-6b82ae2666ae"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/b1a2763c-c321-4506-9f57-6b82ae2666ae"
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    }
  }
}
