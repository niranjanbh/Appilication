# ── Kyros Mobile — Environment Variables ──────────────────────────────────────
#
# Copy this file to .env and fill in the values.
# Expo substitutes EXPO_PUBLIC_* variables at bundle time.
# Changes require a full rebuild (not just a hot reload).

# Backend API base URL (no trailing slash).
# Development: http://localhost:8000
# Staging:     https://staging-api.kyrosclinic.com
# Production:  https://api.kyrosclinic.com
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Razorpay key ID for payment checkout.
# Test key for development, live key for production.
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_REPLACE_ME

# Google OAuth client IDs (one per platform).
# Create these in the Google Cloud Console under your project's OAuth credentials.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
